{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-node",
      "request": "launch",
      "name": "Debug backend with Nx",
      "runtimeExecutable": "/home/vibhor/.nvm/versions/node/v24.12.0/bin/node",
      "program": "${workspaceFolder}/node_modules/nx/bin/nx.js",
      "args": ["serve", "backend"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/dist/apps/backend/**/*.js",
        "!**/node_modules/**"
      ]
    }
  ]
}
